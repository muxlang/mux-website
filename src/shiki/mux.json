{
  "name": "Mux",
  "scopeName": "source.mux",
  "fileTypes": [
    ".mux"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#delimiters"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash",
          "match": "//[^\n]*"
        },
        {
          "name": "comment.block",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block",
              "match": "/\\*.*?\\*/"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(?:if|else|for|while|match|break|continue)\\b"
        },
        {
          "name": "keyword.declaration",
          "match": "\\b(?:auto|func|returns|return|const|class|interface|enum|import|common)\\b"
        },
        {
          "name": "storage.type",
          "match": "\\bauto\\b"
        },
        {
          "name": "keyword.operator",
          "match": "\\b(?:is|as|in)\\b"
        },
        {
          "name": "constant.language",
          "match": "\\b(?:none|true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic",
          "match": "(\\+\\+|--|\\*\\*|/|%|\\+|\\-|\\*)"
        },
        {
          "name": "keyword.operator.assignment",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.comparison",
          "match": "(==|!=|<=|>=)"
        },
        {
          "name": "keyword.operator.logical",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator",
          "match": "(!|&|\\.\\.)"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.integer",
          "match": "[0-9][0-9_]*"
        },
        {
          "name": "constant.numeric.float",
          "match": "([0-9][0-9_]*\\.([0-9][0-9_]*)?|\\.[0-9][0-9_]*)([eE][-+]?[0-9][0-9_]*)?"
        },
        {
          "name": "string.quoted.single",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "string.quoted.triple.double",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\([nrt0\\\\'\" ])"
            }
          ]
        },
        {
          "name": "variable.language",
          "match": "\\b_\\b"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation",
          "match": "[\\(\\)\\{\\}\\[\\]:]"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration"
            },
            "2": {
              "name": "entity.name.function"
            }
          }
        },
        {
          "match": "\\b(class|interface|enum)\\s+([a-zA-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration"
            },
            "2": {
              "name": "entity.name.type"
            }
          }
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "support.function",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b\\s*(?=(?:<[^()<>\\n]+>\\s*)?\\()"
        },
        {
          "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)(\\s*\\.\\s*)([a-zA-Z][a-zA-Z0-9_]*)\\b\\s*(?=(?:<[^()<>\\n]+>\\s*)?\\()",
          "captures": {
            "1": {
              "name": "variable.other"
            },
            "2": {
              "name": "punctuation.delimiter"
            },
            "3": {
              "name": "support.function"
            }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(returns)\\s+([a-zA-Z][a-zA-Z0-9_]*)\b",
          "captures": {
            "1": {
              "name": "keyword.declaration"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(const)\\s+([a-zA-Z][a-zA-Z0-9_]*)\\s+([a-zA-Z][a-zA-Z0-9_]*)\b",
          "captures": {
            "1": {
              "name": "keyword.declaration"
            },
            "2": {
              "name": "storage.type"
            },
            "3": {
              "name": "variable.other"
            }
          }
        },
        {
          "name": "storage.type",
          "match": "\\b(?:string|bool|void|int|float|char|optional|result|list|map|tuple|set|range|Stringable|Hashable|Thread|Error|Self|[A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}